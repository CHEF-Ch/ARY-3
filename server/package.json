{
  "name": "ary-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "tsx src/db.ts --migrate",
    "db:seed": "tsx src/db.ts --seed",
    "test:race-mgmt": "npm run build && node src/modules/race-mgmt/security-smoke-test.mjs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "cors": "^2.8.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
